# Copy to .env and set a long random secret (match secrets.h on the ESP32)
TELEMETRY_SECRET=replace-with-a-long-random-string

# Port (Render/Heroku set PORT automatically)
PORT=3000

# IANA timezone for the trail — controls day/night, powerup daily reset,
# and the "today" boundary. Match the firmware TZ_STRING.
TRAIL_TZ=America/Los_Angeles

# Where the SQLite database lives (default: ./data)
# DATA_DIR=./data
